# Copy to pipeline.env and edit (setup.sh does this automatically):
#   cp pipeline.env.example pipeline.env
#
# Single config file for the whole pipeline: paths, run settings, and API keys.

# --- Paths (ROOT, BENCH, AGENT default from repo root in run_pipeline.sh) ---

# REQUIRED: raw task JSONL (install_config, patch, FAIL_TO_PASS, etc.)
DATASET="/path/to/your/tasks.jsonl"

# Derived SWE-agent instances file (auto-set from DATASET if empty)
SWEAGENT_DATASET=""

# Prefix for run_id values and output discovery (defaults to DATASET basename)
RUN_PREFIX=""

# --- Python environment (created by setup.sh at <repo>/.venv) ---
# VENV defaults to $ROOT/.venv; override only for custom layouts

# --- Harness (SWE-bench-modified) ---
ARCH="x86_64"
MAX_WORKERS_BENCH=4

# Docker Hub namespace; use "none" for local-only images (required on Apple Silicon)
NAMESPACE=none

# Gold gate: minimum fraction of instances that must resolve (0.0–1.0). Set 0 to disable.
MIN_GOLD_RESOLVE_RATE=0.95

# --- Agent (SWE-agent) ---
MAX_WORKERS_AGENT=8
TRIALS="1 2 3 4 5"
REDO_EXISTING=false

AGENT_CONFIG_DEFAULT="config/default.yaml"
AGENT_CONFIG_MODEL="config/opus47.yaml"

# --- Classification (task-analyze) ---
CLASSIFY_AFTER_EVAL=true
ANALYSIS_MODEL="claude-sonnet-4-5"
VERDICT_MODEL="gpt-5.2"
CLASSIFICATION_TIMEOUT=300
VERDICT_TIMEOUT=180

# --- API keys (required for agent + classify steps) ---
# Do not commit pipeline.env once filled in.
GITHUB_TOKEN=""
ANTHROPIC_API_KEY=""
# Optional: use instead of ANTHROPIC_API_KEY for trial classification
# CLAUDE_CODE_OAUTH_TOKEN=""
# Required for verdict synthesis (classify step)
OPENAI_API_KEY=""

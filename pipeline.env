# Copy to pipeline.env and edit paths for your run:
#   cp pipeline.env.example pipeline.env

# --- Paths ---
ROOT="/home/deccan-ai-spark-02/subika/task-quality-and-benchmark"
BENCH="$ROOT/SWE-bench-modified"
AGENT="$ROOT/SWE-agent"

# Raw task JSONL (install_config, patch, FAIL_TO_PASS, etc.)
DATASET="/home/deccan-ai-spark-02/subika/task-quality-and-benchmark/SWE-agent/tasks/pygments_16python_tasks_scoped.jsonl"

# Derived SWE-agent instances file (auto-set from DATASET if empty)
SWEAGENT_DATASET=""

# Prefix for run_id values and output discovery
RUN_PREFIX="pygments_16python_tasks_scoped"

# --- Harness (SWE-bench-modified) ---
ARCH="x86_64"
MAX_WORKERS_BENCH=4

# Docker Hub namespace; use "none" for local-only images (required on Apple Silicon)
NAMESPACE=none

# Gold gate: minimum fraction of instances that must resolve (0.0–1.0). Set 0 to disable.
MIN_GOLD_RESOLVE_RATE=0.95

# --- Agent (SWE-agent) ---
MAX_WORKERS_AGENT=8
TRIALS="1"
REDO_EXISTING=false

AGENT_CONFIG_DEFAULT="config/default.yaml"
AGENT_CONFIG_MODEL="config/opus47.yaml"

# Optional: activate before running sweagent (leave empty to use current shell PATH)
AGENT_VENV="$AGENT/.venv/bin/activate"

# --- Python binaries (override if using venvs) ---
PYTHON_BENCH="python"
PYTHON_AGENT="python"
